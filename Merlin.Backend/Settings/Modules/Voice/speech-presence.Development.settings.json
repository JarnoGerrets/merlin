{
  "SpeechPresence": {
    "Enabled": true,
    "EnableFloorYield": true,
    "FloorYieldRequiresOfficialDecision": true,
    "FloorYieldMinSustainedMs": 30,
    "FloorYieldLogEvidence": true,
    "MaybeConfidenceThreshold": 0.55,
