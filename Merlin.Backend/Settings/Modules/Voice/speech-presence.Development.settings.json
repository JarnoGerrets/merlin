    "ClearNearEndVadConfidence": 0.8,
    "ClearNearEndEchoReducedRms": 0.03,
    "ClearNearEndRawMicRms": 0.05,
    "LogDecisions": true,
    "LogDecisionsToLogger": false,
    "LogDecisionsToFile": true,
    "DecisionLogFilePath": "speech-presence.tmp.log",
    "DecisionLogFlushIntervalMs": 500,
    "DecisionLogMaxQueueEntries": 5000,
    "DecisionLogSampleEveryNFrames": 1
  }
}
